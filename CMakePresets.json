{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-mingw-debug",
      "displayName": "Windows MinGW64 Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/windows-mingw-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_C_COMPILER": "gcc",
        "NOVA3D_BUILD_SANDBOX": "ON",
        "NOVA3D_REQUIRE_OPENGL": "ON"
      }
    },
    {
      "name": "windows-mingw-release",
      "displayName": "Windows MinGW64 Release",
      "inherits": "windows-mingw-debug",
      "binaryDir": "${sourceDir}/build/windows-mingw-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "NOVA3D_BUILD_SANDBOX": "OFF"
      }
    },
    {
      "name": "linux-gcc-debug",
      "displayName": "Linux GCC Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/linux-gcc-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_C_COMPILER": "gcc",
        "NOVA3D_BUILD_SANDBOX": "ON",
        "NOVA3D_REQUIRE_OPENGL": "ON"
      }
    },
    {
      "name": "android-arm64-debug",
      "displayName": "Android arm64-v8a Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/android-arm64-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_TOOLCHAIN_FILE": "$env{ANDROID_NDK}/build/cmake/android.toolchain.cmake",
        "ANDROID_ABI": "arm64-v8a",
        "ANDROID_PLATFORM": "24",
        "ANDROID_STL": "c++_shared",
        "NOVA3D_BUILD_SANDBOX": "OFF",
        "NOVA3D_REQUIRE_OPENGL": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-mingw-debug",
      "configurePreset": "windows-mingw-debug"
    },
    {
      "name": "windows-mingw-release",
      "configurePreset": "windows-mingw-release"
    },
    {
      "name": "linux-gcc-debug",
      "configurePreset": "linux-gcc-debug"
    },
    {
      "name": "android-arm64-debug",
      "configurePreset": "android-arm64-debug"
    }
  ]
}
